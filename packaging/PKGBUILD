# Maintainer: mrthock
pkgname=notispf
pkgver=1.4.4
pkgrel=1
pkgdesc="A terminal text editor inspired by the ISPF editor from z/OS"
arch=('x86_64')
url="https://github.com/mrthock/notispf"
license=('MIT')
depends=('glibc' 'ncurses')
source=("notispf-linux::https://github.com/mrthock/notispf/releases/download/v${pkgver}/notispf-linux")
sha256sums=('08e65e675f122eb574c0f27194ab4d5a4ef5c9938523fd96e69c8936d9d1f945')

package() {
    install -Dm755 "${srcdir}/notispf-linux" "${pkgdir}/usr/bin/notispf"
}
